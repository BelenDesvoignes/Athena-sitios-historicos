# Flask
FLASK_ENV=production
SECRET_KEY=cambia-esto-por-un-secreto-seguro

# Base de datos (Supabase)
# Usar la cadena de conexión con pgbouncer para entornos serverless/contenedores
DATABASE_URL=postgresql+psycopg2://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Almacenamiento de imágenes (Supabase Storage, compatible con S3)
# Endpoint: Dashboard → Storage → S3 Connection
STORAGE_ENDPOINT_URL=https://[PROJECT-REF].supabase.co/storage/v1/s3
STORAGE_ACCESS_KEY=tu-access-key-id
STORAGE_SECRET_KEY=tu-secret-access-key
STORAGE_BUCKET=grupo19

# CORS: URL del portal en Vercel (separar con comas si hay varios)
CORS_ORIGINS=https://tu-portal.vercel.app
